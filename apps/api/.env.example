DATABASE_URL="postgresql://umbra:umbra_dev_password@localhost:5432/umbra_dev"
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# AI
ANTHROPIC_API_KEY="sk-ant-..."

# Email
SENDGRID_API_KEY="SG...."
EMAIL_FROM="alerts@umbra.io"
EMAIL_FROM_NAME="UMBRA Intelligence"

# HIBP
HIBP_API_KEY="your-hibp-api-key"

# Storage (Cloudflare R2 / AWS S3 compatible)
S3_BUCKET="umbra-reports"
S3_REGION="auto"
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID="your-r2-access-key"
S3_SECRET_ACCESS_KEY="your-r2-secret-key"
S3_PUBLIC_URL="https://reports.umbra.io"
